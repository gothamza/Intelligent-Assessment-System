# ===========================================
# JWT Settings
# ===========================================
SECRET_KEY=your-super-secret-key-change-this-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# ===========================================
# Database Credentials
# ===========================================
POSTGRES_DB=odoo_db
POSTGRES_USER=odoo_user
POSTGRES_PASSWORD=odoo_password

# ===========================================
# Application URLs
# ===========================================
BACKEND_URL=http://backend:8000
PUBLIC_BACKEND_URL=http://localhost:8000

# ===========================================
# Ollama LLM URL (for Docker Compose)
# ===========================================
OLLAMA_URL=http://ollama:11434

# ===========================================
# GROQ API Keys
# ===========================================
GROQ_API_KEY=your-groq-api-key-here
GROQ_API_KEY2=your-second-groq-api-key-here
GROQ_API_KEY3=your-third-groq-api-key-here

# GROQ API Keys (comma-separated list for rotation)
GROQ_API_KEYS=your-groq-key-1,your-groq-key-2,your-groq-key-3

# ===========================================
# Other API Keys
# ===========================================
GOOGLE_API_KEY=your-google-api-key-here
OPENAI_API_KEY=your-openai-api-key-here
OPEN_ROUTER=your-openrouter-api-key-here
GITHUB_TOKEN=your-github-token-here
HF_TOKEN=your-huggingface-token-here
TAVILY_API_KEY=your-tavily-api-key-here
GEMINI_API_KEY=your-gemini-api-key-here

# ===========================================
# LangSmith Tracing
# ===========================================
LANGSMITH_TRACING=true
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
LANGSMITH_API_KEY=your-langsmith-api-key-here
LANGSMITH_PROJECT=your-langsmith-project-name

# ===========================================
# Tokenizers Configuration
# ===========================================
TOKENIZERS_PARALLELISM=true
